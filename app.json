{
  "expo": {
    "name": "Отвёртка",
    "slug": "otvertka-mobile",
    "owner": "zakharprotas",
    "version": "2.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.otvertka.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.otvertka.mobile",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-av",
      [
        "expo-build-properties",
        {
          "ios": {
            "infoPlist": {
              "NSMicrophoneUsageDescription": "Приложению нужен доступ к микрофону для голосового управления дефектами и навигации"
            }
          },
          "android": {
            "permissions": [
              "android.permission.RECORD_AUDIO"
            ]
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "bce5f246-91b5-491f-bcf1-28df1ccf3c21"
      }
    },
    "runtimeVersion": "2.0.0",
    "updates": {
      "url": "https://u.expo.dev/bce5f246-91b5-491f-bcf1-28df1ccf3c21"
    }
  }
}
