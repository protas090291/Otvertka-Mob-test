{
  "expo": {
    "name": "Отвёртка",
    "slug": "otvertka-mobile",
    "version": "2.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.otvertka.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.otvertka.mobile",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-av",
      [
        "expo-build-properties",
        {
          "ios": {
            "infoPlist": {
              "NSMicrophoneUsageDescription": "Приложению нужен доступ к микрофону для голосового управления дефектами и навигации"
            }
          },
          "android": {
            "permissions": [
              "android.permission.RECORD_AUDIO"
            ]
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "runtimeVersion": "2.0.0",
    "updates": {
      "url": "https://u.expo.dev/6846e17a-aef6-423e-92d0-44bd7aa58ef0",
      "requestHeaders": {
        "expo-channel-name": "production"
      }
    },
    "extra": {
      "eas": {
        "projectId": "6846e17a-aef6-423e-92d0-44bd7aa58ef0"
      }
    },
    "owner": "zakhar2004"
  }
}
